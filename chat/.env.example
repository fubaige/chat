# ============================================
# Python 智能体配置环境变量配置模板
# ============================================

# --- PostgreSQL 数据库连接配置 ---
# 注意：数据库配置始终从 .env 读取，其他配置可从数据库 system_settings 表动态加载
# 与 Next.js 主应用共享同一个 PostgreSQL 数据库
DB_HOST=localhost
DB_PORT=5432
DB_USER=your-db-username
DB_PASSWORD=your-db-password
DB_NAME=tinyship

# --- 服务间通信配置 ---
# Next.js 与 Python 后端之间的内部 API 密钥，长度至少 32 字符，两端必须一致
INTERNAL_API_KEY=your-internal-api-key-at-least-32-characters
# better-auth 签发 JWT 使用的密钥，与 Next.js 的 BETTER_AUTH_SECRET 保持一致
BETTER_AUTH_SECRET=your-better-auth-secret-key-here
